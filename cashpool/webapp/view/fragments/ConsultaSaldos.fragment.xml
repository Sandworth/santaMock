<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    core:require="{Currency: 'sap/ui/model/type/Currency'}">

    <f:DynamicPage fitContent="true">

        <!-- DynamicPage Title -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text=""/>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- DynamicPage Header — VizFrame column chart (hidden on collapse) -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <viz:VizFrame
                    id="saldosVizFrame"
                    vizType="column"
                    width="100%"
                    height="250px">
                    <viz:dataset>
                        <viz.data:FlattenedDataset data="{empresas>/empresas}">
                            <viz.data:dimensions>
                                <viz.data:DimensionDefinition
                                    name="razonSocial"
                                    value="{razonSocial}"/>
                            </viz.data:dimensions>
                            <viz.data:measures>
                                <viz.data:MeasureDefinition
                                    name="balance"
                                    value="{balance}"/>
                            </viz.data:measures>
                        </viz.data:FlattenedDataset>
                    </viz:dataset>
                    <viz:feeds>
                        <viz.feeds:FeedItem
                            uid="categoryAxis"
                            type="Dimension"
                            values="razonSocial"/>
                        <viz.feeds:FeedItem
                            uid="valueAxis"
                            type="Measure"
                            values="balance"/>
                    </viz:feeds>
                </viz:VizFrame>
            </f:DynamicPageHeader>
        </f:header>

        <!-- DynamicPage Content — Empresas list -->
        <f:content>
            <List
                headerText="Empresas"
                items="{empresas>/empresas}">
                <CustomListItem>
                    <HBox justifyContent="SpaceBetween">
                        <VBox class="sapUiSmallMarginBegin sapUiSmallMarginTopBottom">
                            <Title text="{empresas>razonSocial}"/>
                            <Label text="CIF: {empresas>cif}"/>
                        </VBox>
                        <VBox alignItems="End" class="sapUiSmallMarginEnd sapUiSmallMarginTopBottom">
                            <Label text="Total Balance"/>
                            <Title text="{
                                            parts: [
                                                {path: 'empresas>balance'},
                                                {path: 'empresas>currency'}
                                            ],
                                            type: 'Currency',
                                            formatOptions: {
                                                currencyCode: false,
                                                showMeasure: true
                                            }
                                        }"/>
                        </VBox>
                    </HBox>
                </CustomListItem>
            </List>
        </f:content>

    </f:DynamicPage>

</core:FragmentDefinition>
