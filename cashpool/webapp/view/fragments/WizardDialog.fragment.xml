<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    core:require="{Formatter: 'cashpool/app/cashpool/utils/Formatter'}">
    <Dialog id="wizardDialog"
            title="{i18n>wizardDialogTitle}"
            contentWidth="1420px"
            afterOpen=".onWizardDialogAfterOpen"
            afterClose=".onWizardDialogAfterClose">
        <content>
            <Wizard id="configWizard"
                    renderMode="Page"
                    showNextButton="false"
                    navigationChange=".onWizardNavChange"
                    width="100%">
                <!-- Step 1: Empresa -->
                <WizardStep id="wizardStep1"
                            title="{i18n>wizardStep1Title}"
                            validated="false">
                    <VBox width="80%" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                        <SearchField 
                                    placeholder="{i18n>wizardSearchStep1Placeholder}"
                                    search=".onEmpresaSearch"
                                    class="sapUiSmallMarginBottom"/>
                        <Table id="empresaTable"
                                items="{wizard>/empresas}"
                                mode="SingleSelectLeft"
                                selectionChange=".onEmpresaSelectionChange"
                                fixedLayout="false">
                            <columns>
                                <Column>
                                    <header>
                                        <Text text="{i18n>colRazonSocial}"/>
                                    </header>
                                </Column>
                                <Column>
                                    <header>
                                        <Text text="{i18n>colCNPJ}"/>
                                    </header>
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem type="Active">
                                    <cells>
                                        <Text text="{wizard>razonSocial}"/>
                                        <Text text="{wizard>cnpj}"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </WizardStep>
                <!-- Step 2: Cuentas -->
                <WizardStep id="wizardStep2"
                            title="{i18n>wizardStep2Title}"
                            validated="false">
                    <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                        <SearchField width="100%"
                                     placeholder="{i18n>wizardSearchStep2Placeholder}"
                                     search=".onCuentasSearch"/>
                        <List id="bancosListStep2"
                              items="{wizard>/bancos}"
                              mode="None"
                              showSeparators="None">
                            <CustomListItem>
                                <Panel expandable="true"
                                       expanded="{wizard>expanded}"
                                       headerText="{parts: [{path: 'wizard>nombre'}, {path: 'wizard>cuentas'}], formatter: 'Formatter.formatBankTitle'}"
                                       class="sapUiSmallMarginBottom">
                                    <Table items="{wizard>cuentas}"
                                           mode="MultiSelect"
                                           selectionChange=".onCuentasSelectionChange"
                                           fixedLayout="false">
                                        <columns>
                                            <Column>
                                                <header>
                                                    <Text text="{i18n>colNombre}"/>
                                                </header>
                                            </Column>
                                            <Column>
                                                <header>
                                                    <Text text="{i18n>colOficina}"/>
                                                </header>
                                            </Column>
                                            <Column>
                                                <header>
                                                    <Text text="{i18n>colCuentaCorriente}"/>
                                                </header>
                                            </Column>
                                            <Column hAlign="End">
                                                <header>
                                                    <Text text="{i18n>colSaldoSAP}"/>
                                                </header>
                                            </Column>
                                            <Column hAlign="End">
                                                <header>
                                                    <Text text="{i18n>colSaldoInfoCent}"/>
                                                </header>
                                            </Column>
                                            <Column hAlign="Center">
                                                <header>
                                                    <Text text="{i18n>colOrigenSaldo}"/>
                                                </header>
                                            </Column>
                                        </columns>
                                        <items>
                                            <ColumnListItem type="Active">
                                                <cells>
                                                    <HBox alignItems="Center">
                                                        <Text text="{wizard>nombre}" class="sapUiTinyMarginEnd"/>
                                                        <ObjectStatus inverted="true" text="{i18n>autorizado}"/>
                                                    </HBox>
                                                    <Text text="{wizard>oficina}"/>
                                                    <Text text="{wizard>cuentaCorriente}"/>
                                                    <Text text="{parts: [{path: 'wizard>saldoSAP'}, {path: 'wizard>currency'}], formatter: 'Formatter.formatCurrency'}"/>
                                                    <Text text="{parts: [{path: 'wizard>saldoInfoCent'}, {path: 'wizard>currency'}], formatter: 'Formatter.formatCurrency'}"/>
                                                    <RadioButtonGroup
                                                                    templateShareable="true"
                                                                    columns="2"
                                                                    select="">
                                                        <buttons>
                                                            <RadioButton text="{i18n>colSaldoSAP}"/>
                                                            <RadioButton text="{i18n>colSaldoInfoCent}"/>
                                                        </buttons>
                                                    </RadioButtonGroup>                                                    
                                                </cells>
                                            </ColumnListItem>
                                        </items>
                                    </Table>
                                </Panel>
                            </CustomListItem>
                        </List>
                    </VBox>
                </WizardStep>
                <!-- Step 3: Cuenta Centralizadora -->
                <WizardStep id="wizardStep3"
                            title="{i18n>wizardStep3Title}"
                            validated="false">
                    <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                        <SearchField width="100%"
                                     placeholder="{i18n>wizardSearchStep3Placeholder}"
                                     search=".onCuentaCentralSearch"
                                     class="sapUiSmallMarginBottom"/>
                        <Table id="cuentaCentralTable"
                               items="{wizard>/cuentasCentralizadoras}"
                               mode="SingleSelectLeft"
                               selectionChange=".onCuentaCentralSelectionChange"
                               fixedLayout="false">
                            <columns>
                                <Column width="40%">
                                    <header>
                                        <Text text="{i18n>colNombre}"/>
                                    </header>
                                </Column>
                                <Column width="30%">
                                    <header>
                                        <Text text="{i18n>colOficina}"/>
                                    </header>
                                </Column>
                                <Column width="30%">
                                    <header>
                                        <Text text="{i18n>colCuentaCorriente}"/>
                                    </header>
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem type="Active">
                                    <cells>
                                        <Text text="{wizard>nombre}"/>
                                        <Text text="{wizard>oficina}"/>
                                        <Text text="{wizard>cuentaCorriente}"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </WizardStep>
                <!-- Step 4: Configuración -->
                <WizardStep id="wizardStep4"
                            title="{i18n>wizardStep4Title}"
                            validated="true">
                    <VBox class="sapUiSmallMarginBeginEnd sapUiMediumMarginTop sapUiContentPadding">
                        <Title text="{i18n>wizardQuestion1}" level="H5" class="sapUiSmallMarginBottom"/>
                        <RadioButtonGroup id="horarioGroup"
                                          columns="1"
                                          selectedIndex="{wizard>/selectedHorario}"
                                          select=".onHorarioSelectionChange">
                            <buttons>
                                <RadioButton text="{i18n>wizardHorario1}"/>
                                <RadioButton text="{i18n>wizardHorario2}"/>
                                <RadioButton text="{i18n>wizardHorario3}"/>
                            </buttons>
                        </RadioButtonGroup>
                        <VBox
                            class="sapUiSmallMarginTop"
                            visible="{= ${wizard>/selectedHorario} === 0 }">
                            <Label text="{i18n>wizardSelectHorarioLabel}" class="sapUiTinyMarginBottom"/>
                            <Select
                                width="12rem"
                                selectedKey="{wizard>/horarioUnico}"
                                change=".onHorarioUnicoChange"
                                items="{wizard>/horariosUnicos}">
                                <core:Item key="{wizard>key}" text="{wizard>text}"/>
                            </Select>
                        </VBox>
                        <Title text="{i18n>wizardQuestion2}" level="H5" class="sapUiMediumMarginTop sapUiSmallMarginBottom"/>
                        <HBox wrap="Wrap">
                            <CheckBox text="{i18n>weekdayLunes}"     selected="{wizard>/dias/lunes}"     select=".onDiaSelectionChange" class="sapUiSmallMarginEnd"/>
                            <CheckBox text="{i18n>weekdayMartes}"    selected="{wizard>/dias/martes}"    select=".onDiaSelectionChange" class="sapUiSmallMarginEnd"/>
                            <CheckBox text="{i18n>weekdayMiercoles}" selected="{wizard>/dias/miercoles}" select=".onDiaSelectionChange" class="sapUiSmallMarginEnd"/>
                            <CheckBox text="{i18n>weekdayJueves}"    selected="{wizard>/dias/jueves}"    select=".onDiaSelectionChange" class="sapUiSmallMarginEnd"/>
                            <CheckBox text="{i18n>weekdayViernes}"   selected="{wizard>/dias/viernes}"   select=".onDiaSelectionChange" class="sapUiSmallMarginEnd"/>
                            <CheckBox text="{i18n>weekdaySabado}"    selected="{wizard>/dias/sabado}"    select=".onDiaSelectionChange" class="sapUiSmallMarginEnd"/>
                            <CheckBox text="{i18n>weekdayDomingo}"   selected="{wizard>/dias/domingo}"   select=".onDiaSelectionChange" class="sapUiSmallMarginEnd"/>
                        </HBox>
                    </VBox>
                </WizardStep>
                <!-- Step 5: Adicional -->
                <WizardStep id="wizardStep5"
                            title="{i18n>wizardStep5Title}"
                            validated="false">
                    <VBox class="sapUiSmallMarginBeginEnd sapUiMediumMarginTop sapUiContentPadding">
                        <Title text="{i18n>wizardQuestion3}" level="H5" class="sapUiSmallMarginBottom"/>
                        <RadioButtonGroup id="saldoGroup"
                                          columns="1"
                                          selectedIndex="{wizard>/selectedSaldoType}"
                                          select=".onSaldoSelectionChange">
                            <buttons>
                                <RadioButton text="{i18n>wizardSaldo1}"/>
                                <RadioButton text="{i18n>wizardSaldo2}"/>
                                <RadioButton text="{i18n>wizardSaldo3}"/>
                            </buttons>
                        </RadioButtonGroup>
                    </VBox>
                </WizardStep>
                <!-- Step 6: Revisión -->
                <WizardStep id="wizardStep6"
                            title="{i18n>wizardStep6Title}"
                            validated="true"
                            activate=".onReviewStepActivate">
                    <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                        <!-- 1. Empresa -->
                        <Panel expandable="false" class="sapUiSmallMarginBottom">
                            <headerToolbar>
                                <Toolbar>
                                    <Title text="{i18n>wizardReviewSection1}" level="H5"/>
                                    <ToolbarSpacer/>
                                    <Link text="{i18n>editLink}" press=".onEditStep" data:step="1"/>
                                </Toolbar>
                            </headerToolbar>
                            <form:SimpleForm editable="false" layout="ResponsiveGridLayout"
                                             labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                                             adjustLabelSpan="false" columnsXL="1" columnsL="1" columnsM="1">
                                <form:content>
                                    <Label text="{i18n>colRazonSocial}"/>
                                    <Text text="{wizard>/review/razonSocial}"/>
                                    <Label text="{i18n>colCNPJ}"/>
                                    <Text text="{wizard>/review/cnpj}"/>
                                </form:content>
                            </form:SimpleForm>
                        </Panel>
                        <!-- 2. Cuentas -->
                        <Panel expandable="false" class="sapUiSmallMarginBottom">
                            <headerToolbar>
                                <Toolbar>
                                    <Title text="{i18n>wizardReviewSection2}" level="H5"/>
                                    <ToolbarSpacer/>
                                    <Link text="{i18n>editLink}" press=".onEditStep" data:step="2"/>
                                </Toolbar>
                            </headerToolbar>
                            <form:SimpleForm editable="false" layout="ResponsiveGridLayout"
                                             labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                                             adjustLabelSpan="false" columnsXL="1" columnsL="1" columnsM="1">
                                <form:content>
                                    <Label text="{i18n>colCuentasSeleccionadas}"/>
                                    <Text text="{wizard>/review/cuentasSeleccionadas}"/>
                                </form:content>
                            </form:SimpleForm>
                        </Panel>
                        <!-- 3. Cuenta Centralizadora -->
                        <Panel expandable="false" class="sapUiSmallMarginBottom">
                            <headerToolbar>
                                <Toolbar>
                                    <Title text="{i18n>wizardReviewSection3}" level="H5"/>
                                    <ToolbarSpacer/>
                                    <Link text="{i18n>editLink}" press=".onEditStep" data:step="3"/>
                                </Toolbar>
                            </headerToolbar>
                            <form:SimpleForm editable="false" layout="ResponsiveGridLayout"
                                             labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                                             adjustLabelSpan="false" columnsXL="1" columnsL="1" columnsM="1">
                                <form:content>
                                    <Label text="{i18n>colBanco}"/>
                                    <Text text="{wizard>/review/cuentaCentralNombre}"/>
                                    <Label text="{i18n>colCuentaCorriente}"/>
                                    <Text text="{wizard>/review/cuentaCentralCuenta}"/>
                                </form:content>
                            </form:SimpleForm>
                        </Panel>
                        <!-- 4. Configuración -->
                        <Panel expandable="false" class="sapUiSmallMarginBottom">
                            <headerToolbar>
                                <Toolbar>
                                    <Title text="{i18n>wizardReviewSection4}" level="H5"/>
                                    <ToolbarSpacer/>
                                    <Link text="{i18n>editLink}" press=".onEditStep" data:step="4"/>
                                </Toolbar>
                            </headerToolbar>
                            <form:SimpleForm editable="false" layout="ResponsiveGridLayout"
                                             labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                                             adjustLabelSpan="false" columnsXL="1" columnsL="1" columnsM="1">
                                <form:content>
                                    <Label text="{i18n>wizardQuestion1Short}"/>
                                    <Text text="{wizard>/review/horario}"/>
                                    <Label text="{i18n>wizardQuestion2Short}"/>
                                    <Text text="{wizard>/review/dias}"/>
                                </form:content>
                            </form:SimpleForm>
                        </Panel>
                        <!-- 5. Adicional -->
                        <Panel expandable="false">
                            <headerToolbar>
                                <Toolbar>
                                    <Title text="{i18n>wizardReviewSection5}" level="H5"/>
                                    <ToolbarSpacer/>
                                    <Link text="{i18n>editLink}" press=".onEditStep" data:step="5"/>
                                </Toolbar>
                            </headerToolbar>
                            <form:SimpleForm editable="false" layout="ResponsiveGridLayout"
                                             labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                                             adjustLabelSpan="false" columnsXL="1" columnsL="1" columnsM="1">
                                <form:content>
                                    <Label text="{i18n>wizardQuestion3Short}"/>
                                    <Text text="{wizard>/review/saldoAdicionalData}"/>
                                </form:content>
                            </form:SimpleForm>
                        </Panel>
                    </VBox>
                </WizardStep>
            </Wizard>
        </content>
        <buttons>
            <Button text="{i18n>wizardCancelBtn}" press=".onWizardCancel"/>
            <Button text="{i18n>wizardBackBtn}" visible="{wizard>/nav/backVisible}" press=".onWizardBack"/>
            <Button text="{i18n>wizardNextBtn}" type="Emphasized" visible="{wizard>/nav/nextVisible}" enabled="{wizard>/nav/nextEnabled}" press=".onWizardNext"/>
            <Button text="{i18n>wizardAcceptBtn}" type="Emphasized" visible="{wizard>/nav/acceptVisible}" press=".onWizardAccept"/>
        </buttons>
    </Dialog>
</core:FragmentDefinition>