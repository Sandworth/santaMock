<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">
    <Dialog id="configurationDialog" title="{i18n>dialogTitle}" afterClose=".onDialogClose" contentWidth="700px">
        <content>
            <l:VerticalLayout class="sapUiContentPadding" width="100%">
                <IllustratedMessage illustrationSize="Large" illustrationType="sapIllus-SuccessHighFive" title="{i18n>dialogIllustratedTitle}" description="{i18n>dialogIllustratedMessage}" enableDefaultTitleAndDescription="false"/>
            </l:VerticalLayout>
        </content>
        <buttons>
            <Button text="{i18n>configureNowBtn}" type="Emphasized" press=".onConfigureNow"/>
            <Button text="{i18n>closeBtn}" press=".onCloseDialog"/>
        </buttons>
    </Dialog>
</core:FragmentDefinition>
